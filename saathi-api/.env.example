# ─────────────────────────────────────────────
#  Saathi API — Environment Configuration
#  Copy / rename this to .env and fill in ONE key
# ─────────────────────────────────────────────

# ── OPTION 1: Google Gemini (RECOMMENDED — FREE TIER) ──
# Get key at: https://aistudio.google.com/app/apikey
# Free limits: 15 RPM, 1M tokens/min, no credit card needed
GEMINI_API_KEY=

# Optional: override model (default is gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# ── OPTION 2: Anthropic Claude ──
# Get key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── OPTION 3: OpenAI ──
# Get key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# If NO LLM key is set, Saathi runs in offline mode
# and will prompt you to add one.
# ─────────────────────────────────────────────

# ── MODULE 12: VOICE INTERFACE ───────────────────────────

# STT: Whisper model size — tiny (fast, ~75MB) | base (~150MB) | small (~500MB)
# WHISPER_MODEL=tiny

# Wake words (comma-separated, matched in Whisper transcription)
# VOICE_WAKE_WORDS=hey saathi,saathi

# TTS Option A — ElevenLabs (cloud, high quality, free tier: 10k chars/month)
# Get key at: https://elevenlabs.io/
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# TTS Option B — pyttsx3 (local, always works, no key needed)
# (default if ELEVENLABS_API_KEY is not set)

# Wake Word Option — Picovoice Porcupine (optional, more accurate)
# Free tier available at: https://console.picovoice.ai/
# PICOVOICE_KEY=
