# Public URLs used for OAuth redirects and mobile links
PUBLIC_API_URL=http://localhost:8000
PUBLIC_WEB_URL=http://localhost:5173
APP_TIMEZONE=Asia/Kolkata

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Workspace OAuth
# Use the "Web application" OAuth client from Google Cloud and copy the
# client_id + client_secret values from the downloaded JSON file.
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_STATE_SECRET=your-oauth-state-secret

# LLM fallback order
LLM_PROVIDER_ORDER=gemini,openai,anthropic

# Free-first recommendation
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# Optional paid backups
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
