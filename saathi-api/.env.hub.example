# ═══════════════════════════════════════════════════════════════════════════════
#  SAATHI CLOUD HUB — Environment Configuration
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── 1. JWT AUTHENTICATION ──────────────────────────────────────────────────────
# Generate a secure secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Pre-shared key for daemon authentication (daemon uses this to get a JWT)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
DAEMON_PSK=CHANGE_ME_TO_A_RANDOM_PSK

# ── 2. LLM PROVIDERS (FREE TIER — NO PAID APIs) ──────────────────────────────
# Hugging Face Inference API (Primary — Gemma)
# Get key: https://huggingface.co/settings/tokens
HF_API_KEY=hf_YOUR_HUGGINGFACE_TOKEN_HERE

# Model selection for HF Inference
GEMMA_MODEL=google/gemma-3-12b-it
GEMMA_FALLBACK=google/gemma-2-9b-it
LLAMA_MODEL=meta-llama/Llama-3.3-70B-Instruct
MIXTRAL_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# Groq Cloud (Fallback — Ultra-fast Llama inference)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=llama-3.1-8b-instant

# Local Ollama (Edge model — runs on daemon machine)
OLLAMA_URL=http://localhost:11434
LOCAL_MODEL=gemma2:2b

# ── 3. REDIS (Message Broker & Daemon Registry) ───────────────────────────────
# Local: redis://localhost:6379
# Upstash (Free): redis://default:PASSWORD@HOST:PORT
# Railway: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# ── 4. CLOUD HUB SERVER ───────────────────────────────────────────────────────
HUB_HOST=0.0.0.0
HUB_PORT=7860
CORS_ORIGINS=*

# ── 5. DAEMON CONFIGURATION (for edge daemon .env) ────────────────────────────
# These go in the daemon's .env on the user's physical machine
HUB_WS_URL=ws://localhost:7860/ws/daemon
DAEMON_TOKEN=YOUR_DAEMON_JWT_TOKEN_HERE
DAEMON_ID=daemon-my-laptop
SAATHI_WORKSPACE=~/saathi_workspace
HEARTBEAT_INTERVAL=30

# ── 6. CLOUD WORKSPACE FALLBACK ───────────────────────────────────────────────
CLOUD_WORKSPACE_IMAGE=python:3.11-slim
CLOUD_WORKSPACE_TIMEOUT=120
# GitHub PAT for cloning private repos (optional)
GITHUB_TOKEN=

# ── 7. EXISTING SAATHI INTEGRATIONS (from v2) ─────────────────────────────────
# These are carried forward for backward compatibility
GEMINI_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_STATE_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
PUBLIC_API_URL=http://localhost:8000
PUBLIC_WEB_URL=http://localhost:5173
APP_TIMEZONE=Asia/Kolkata
